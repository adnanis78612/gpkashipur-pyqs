<style>
  *{
    box-sizing:border-box;
  }

  body{
    margin:0;
  }

  .page{
    min-height:100vh;
    background:
      radial-gradient(circle at top,#1e3a8a,#0f172a 60%);
    display:flex;
    justify-content:center;
    align-items:center;
    padding:40px 20px;
  }

  .card{
    width:100%;
    max-width:550px;
    background:rgba(255,255,255,0.05);
    border:1px solid rgba(255,255,255,0.1);
    backdrop-filter:blur(18px);
    border-radius:24px;
    padding:40px;
    box-shadow:0 10px 40px rgba(0,0,0,0.5);
  }

  h1{
    color:white;
    font-size:42px;
    margin-bottom:10px;
  }

  .subtitle{
    color:#cbd5e1;
    margin-bottom:30px;
  }

  .field{
    margin-bottom:22px;
  }

  label{
    display:block;
    color:white;
    margin-bottom:10px;
    font-weight:600;
  }

  input,
  select{
    width:100%;
    height:52px;
    border:none;
    outline:none;
    border-radius:14px;
    padding:0 16px;
    font-size:16px;
    background:rgba(255,255,255,0.08);
    color:white;
    border:1px solid rgba(255,255,255,0.08);
  }

  input[type="file"]{
    padding:12px;
    height:auto;
  }

  button{
    width:100%;
    height:55px;
    border:none;
    border-radius:16px;
    background:linear-gradient(135deg,#6366f1,#8b5cf6);
    color:white;
    font-size:17px;
    font-weight:700;
    cursor:pointer;
    margin-top:10px;
  }

  button:hover{
    opacity:0.95;
  }

  .success{
    text-align:center;
    color:white;
  }

.home-btn{
  display:inline-block;
  margin-top:25px;
  padding:14px 24px;
  border-radius:14px;
  background:#ed0000;
  color:white !important;
  text-decoration:none;
  font-weight:600;
}

.home-btn:visited{
  color:white !important;
}

.home-btn:hover{
  color:white !important;
}

.home-btn:active{
  color:white !important;
}
</style>

<div class="page">

  <div class="card">

    <h1>Upload PYQ PDF</h1>

    <p class="subtitle">
      Help students by contributing previous year question papers.
    </p>

    <form id="uploadForm">

      <div class="field">
        <label>Your Name</label>

        <input
          type="text"
          name="contributor"
          placeholder="Enter your name"
          required
        >
      </div>

      <div class="field">
        <label>Course</label>

        <input
          type="text"
          name="course"
          placeholder="Example: Diploma CS"
          required
        >
      </div>

      <div class="field">
        <label>Year / Semester</label>

        <input
          type="text"
          name="year"
          placeholder="Example: 1st Sem"
          required
        >
      </div>

      <div class="field">
        <label>Subject</label>

        <input
          type="text"
          name="subject"
          placeholder="Subject name"
          required
        >
      </div>

      <div class="field">
        <label>Exam Type</label>

        <select name="examType">
          <option>Mid Sem</option>
          <option>End Sem</option>
        </select>
      </div>

      <div class="field">
        <label>Select PDF</label>

        <input
          type="file"
          name="pdf"
          accept=".pdf"
          required
        >
      </div>

      <button type="submit">
        Upload PDF
      </button>

    </form>

  </div>

</div>

<script>
  const form = document.getElementById("uploadForm");

  form.addEventListener("submit", async (e) => {

    e.preventDefault();

    const formData = new FormData(form);

    const response = await fetch("/api/upload", {
      method: "POST",
      body: formData,
    });

    const result = await response.json();

    if(result.success){

    document.querySelector(".card").innerHTML = `
    <div class="success">

    <h1 style="color:white;">
      ✅ Upload Successful
    </h1>

    <p style="color:#e2e8f0; font-size:18px; margin-top:18px;">
      Your PDF has been submitted successfully.
    </p>

    <p style="color:#cbd5e1; margin-top:10px;">
      Waiting for admin approval.
    </p>

<a 
  href="/" 
  class="home-btn"
  style="
    color:red !important;
    text-decoration:none;
  "
>
  Go Back Home
</a>

    </div>
    `;

    }else{

      alert("Upload Failed");
      console.log(result);

    }

  });
</script>

