---
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>

  <title>Upload PYQ</title>
</head>

<body style="background:#0f172a;color:white;font-family:sans-serif;padding:40px;">

<h1>Upload PYQ PDF</h1>

<form
  id="uploadForm"
  enctype="multipart/form-data"
  style="display:flex;flex-direction:column;gap:15px;max-width:400px;"
>

  <input
    type="text"
    name="contributor"
    placeholder="Your Name"
    required
    style="height:45px;padding:10px;"
  >

  <input
    type="text"
    name="course"
    placeholder="Course"
    required
    style="height:45px;padding:10px;"
  >

  <input
    type="text"
    name="year"
    placeholder="Year / Semester"
    required
    style="height:45px;padding:10px;"
  >

  <input
    type="text"
    name="subject"
    placeholder="Subject"
    required
    style="height:45px;padding:10px;"
  >

  <select
    name="examType"
    style="height:45px;padding:10px;"
  >
    <option value="Mid Sem">Mid Sem</option>
    <option value="End Sem">End Sem</option>
  </select>

  <input
    type="file"
    name="pdf"
    accept=".pdf"
    required
  >

  <button
    type="submit"
    style="
      padding:14px;
      background:#4f46e5;
      color:white;
      border:none;
      border-radius:10px;
      cursor:pointer;
      font-size:16px;
    "
  >
    Upload PDF
  </button>

</form>

<p id="message"></p>

<script is:inline>
  const form = document.getElementById("uploadForm");
  const message = document.getElementById("message");

  form.addEventListener("submit", async (e) => {
    e.preventDefault();

    message.innerText = "Uploading PDF...";

    const formData = new FormData(form);

    try {
      const response = await fetch("/api/upload/", {
        method: "POST",
        body: formData,
      });

      const result = await response.json();

      if (result.success) {
        message.innerText =
          "✅ PDF uploaded successfully! Waiting for admin approval.";

        form.reset();
      } else {
        message.innerText =
          "❌ Upload failed";
          
        console.log(result);
      }

    } catch (err) {
      console.log(err);

      message.innerText =
        "❌ Something went wrong";
    }
  });
</script>

</body>
</html>