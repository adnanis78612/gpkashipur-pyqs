---
import PdfViewer from "@/components/widgets/PdfViewer.astro";
import BaseLayout from "./BaseLayout.astro";
import type { FsEntry } from "@/lib/content/schema";

interface Props {
	entry: FsEntry<"file">;
}

const { entry } = Astro.props;

const src = `/pyqs${entry.path}`.replaceAll(" ", "%20");
---

<BaseLayout
	title={entry.name}
	description={entry.path}
>
	<PdfViewer src={src} />
</BaseLayout>